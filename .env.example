# AWS Bedrock (used for Claude model inference)
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=ap-southeast-2

# Google Gemini
GEMINI_API_KEY=

# DeepSeek V4 Pro (server-only NVIDIA-compatible endpoint)
NVIDIA_API_KEY=
# Optional partner endpoint overrides if the direct endpoint is unavailable.
DEEPSEEK_V4_PRO_BASE_URL=
DEEPSEEK_V4_PRO_API_KEY=
DEEPSEEK_V4_PRO_MODEL=deepseek-ai/deepseek-v4-pro

# Qwen-Image (server-only Visual GenAI NIM endpoint)
# NVIDIA_IMAGE_API_KEY falls back to NVIDIA_API_KEY when empty.
NVIDIA_IMAGE_API_KEY=
NVIDIA_IMAGE_BASE_URL=
NVIDIA_IMAGE_MODEL=

# Tavily (web search)
TAVILY_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
