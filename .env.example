# AWS Bedrock (used for Claude model inference)
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=ap-southeast-2

# Google Gemini
GEMINI_API_KEY=

# Primary chat deployment via Azure AI Foundry (server-only chat routing).
# ALL chat tiers route here. Works with any OpenAI-compatible deployment
# (e.g. gpt-5.6-sol, DeepSeek-V4-Pro).
AZURE_GPT54_API_KEY=
AZURE_GPT54_BASE_URL=https://easyplus-resource.services.ai.azure.com/openai/v1
AZURE_GPT54_MODEL=gpt-5.6-sol
# Optional: force image handling. Default: images go natively to the deployment
# when its name contains "gpt" (vision-capable); otherwise Gemini reads them.
# Set to true/false to override the auto-detection.
AZURE_GPT54_VISION=

# DeepSeek V4 Pro via Azure AI Foundry / Azure OpenAI (server-only)
AZURE_DEEPSEEK_API_KEY=
AZURE_DEEPSEEK_BASE_URL=https://brandneweasyplusshitmid-resource.services.ai.azure.com/openai/v1
AZURE_DEEPSEEK_MODEL=DeepSeek-V4-Pro

# Image Generation via Azure AI Foundry / Azure OpenAI (server-only)
AZURE_IMAGE_API_KEY=
AZURE_IMAGE_BASE_URL=https://brandneweasyplusshitmid-resource.services.ai.azure.com/openai/v1
AZURE_IMAGE_MODEL=gpt-image-2

# Tavily (web search)
TAVILY_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
